{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/_bucket/:path*",
      "destination": "https://prod-packager-packages.codesandbox.io/:path*"
    },
    {
      "source": "/_packager/:path*",
      "destination": "https://aiwi8rnkp5.execute-api.eu-west-1.amazonaws.com/prod/packages/:path*"
    }
  ]
}
